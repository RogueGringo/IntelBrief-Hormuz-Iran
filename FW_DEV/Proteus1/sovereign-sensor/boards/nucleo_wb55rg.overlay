/*
 * Device tree overlay for STEVAL-PROTEUS1 sensor board.
 *
 * Pin mapping from official STM32CubeMX IOC (STM32_open_pin_data):
 *
 * ISM330DHCX on SPI1: SCK=PA5, MISO=PA6, MOSI=PB5, CS=PA4
 * IIS3DWB on SPI1: CS=PA15 (not used Phase 1)
 * IIS2DLPC on I2C1: SCL=PB8, SDA=PB7
 * STTS22H on I2C1
 * STSAFE on I2C1
 *
 * Power: STBC02_CEN=PD12 (OD, HIGH), ST1PS02 D0=PC9,D1=PC10,D2=PC11
 *        ST1PS02_AUX=PD13 (HIGH), STBC02_WAKE-UP=PH0
 *
 * Using nucleo_wb55rg as base board (same STM32WB55 SoC).
 */

&spi1 {
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pb5>;
	pinctrl-names = "default";
	status = "okay";
	cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>,
	           <&gpioa 15 GPIO_ACTIVE_LOW>;

	ism330dhcx@0 {
		compatible = "st,ism330dhcx";
		reg = <0>;
		spi-max-frequency = <10000000>;
	};

	/*
	 * IIS3DWB (CS1/PA15): 26.7kHz vibration sensor.
	 * No Zephyr driver — accessed via raw SPI in impact_detect.c
	 * using the second cs-gpios entry above.
	 */
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb7>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	/* IIS2DLPC: ultra-low-power accel for wake-on-motion */
	iis2dlpc: iis2dlpc@18 {
		compatible = "st,iis2dlpc";
		reg = <0x18>;
	};

	/* STTS22H: temperature sensor for drift compensation */
	stts22h: stts22h@3f {
		compatible = "st,stts22h";
		reg = <0x3f>;
		sampling-rate = <0x04>;  /* STTS22H_1Hz — continuous 1Hz */
	};
};

/* Console on lpuart1 */
/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};
};

&lpuart1 {
	pinctrl-0 = <&lpuart1_rx_pc0 &lpuart1_tx_pc1>;
	pinctrl-names = "default";
	status = "okay";
	current-speed = <115200>;
};

/*
 * QuadSPI NOR flash: MX25R6435F 64Mbit (8MB)
 * QSPI: CLK=PA3, IO0=PB9, IO1=PD5, IO2=PD6, IO3=PD7, NCS=PB11
 * TODO: Enable when custom pinctrl with PD5-7 QSPI pins is added.
 *       The nucleo_wb55rg pinctrl lacks PD5-7 QSPI definitions.
 *       Need stm32wb5mmghx-pinctrl.dtsi for these pins.
 */

&zephyr_udc0 {
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};
