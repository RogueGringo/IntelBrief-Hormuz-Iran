# Sovereign Motion — Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# ─── Security ─────────────────────────────────────────────
# API key for authenticating requests (optional — leave blank for open access)
SOVEREIGN_API_KEY=

# Allowed CORS origins (comma-separated, default: * in dev)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ─── Paths ────────────────────────────────────────────────
# Path to sovereign-lib (default: ../sovereign-lib relative to hf-proxy)
SOVEREIGN_LIB_PATH=

# Data directory (default: hf-proxy/data)
SOVEREIGN_DATA_DIR=

# ─── Server ───────────────────────────────────────────────
# Host and port for the FastAPI backend
HOST=0.0.0.0
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Upload Limits ────────────────────────────────────────
# Maximum upload file size in MB
MAX_UPLOAD_MB=50

# ─── Rate Limiting ────────────────────────────────────────
# Default rate limit (requests per minute)
RATE_LIMIT=60/minute

# ─── LLM ──────────────────────────────────────────────────
# GPU model path (GGUF file for fast classification)
LLM_GPU_MODEL=

# CPU model path (GGUF file for coaching/distillation)
LLM_CPU_MODEL=

# ─── Webhooks ─────────────────────────────────────────────
# Webhook timeout in seconds
WEBHOOK_TIMEOUT=10
